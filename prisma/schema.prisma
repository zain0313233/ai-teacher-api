// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER      // Students - default role, current dashboard
  TEACHER   // Teachers - new portal needed
  ADMIN     // Admins - new portal needed
}

enum PlanType {
  FREE
  BASIC
  PRO
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          UserRole       @default(USER)
  plan          PlanType       @default(FREE)
  isVerified    Boolean        @default(false)
  emailNotifyAssignments  Boolean @default(true)
  emailNotifyDueReminders Boolean @default(true)
  inAppNotifications      Boolean @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  refreshTokens  RefreshToken[]
  documents      Document[]
  exams          Exam[]
  patterns       Pattern[]
  pastPapers     PastPaper[]
  otpCodes       OtpCode[]
  passwordResets PasswordReset[]
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  chatSessions   ChatSession[]
  quizSessions   QuizSession[]
  quizAttempts   QuizAttempt[]
  notifications  Notification[]
  classroomsTaught   Classroom[]       @relation("TeacherClassrooms")
  classEnrollments   ClassEnrollment[] @relation("StudentEnrollments")
  classMaterialsShared ClassMaterial[]
  classAssignmentsCreated ClassAssignment[]
  classMessagesSent     ClassMessage[]
  questionBanks         QuestionBank[]

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Document {
  id            String   @id @default(uuid())
  userId        String
  
  // Universal metadata
  documentType  String   @default("textbook") // textbook | past_paper | notes | reference | question_bank
  
  // Education system hierarchy
  educationSystem String @default("punjab_board") // punjab_board, federal_board, css_exam, nust, etc.
  level         String   @default("matric") // matric, fsc, bs, ms, phd, competitive
  class         String?  // For matric: "9" or "10", For FSc: "11" or "12", For BS: "BS-CS-3", etc.
  subject       String?  // mathematics, physics, urdu, etc.
  year          Int?
  board         String?  // punjab_board, fpsc, nust, etc.
  examType      String?  // mid_term, final, annual, written, etc.
  language      String   @default("english") // english, urdu, mixed
  
  // File info
  fileName      String
  fileType      String
  fileUrl       String
  fileSize      Int
  
  // Processing info
  uploadMode    String   @default("auto") // auto, chapter, fullbook, manual
  chapterNumber Int?     // For chapter uploads
  chapterName   String?  // For chapter uploads
  processed     Boolean  @default(false)
  extractionMethod String? // pymupdf, ocr, vision_model, manual
  extractionQuality Float? // 0.0 - 1.0
  verified      Boolean  @default(false)
  isOfficial    Boolean  @default(false) // Admin-uploaded official content
  
  // Multi-tier knowledge system fields
  contentTier   String   @default("curriculum") // curriculum, conceptual, research, practical
  topic         String?  // Main topic (e.g., "Gravity", "Newton's Laws")
  concept       String?  // Specific concept (e.g., "First Law of Motion")
  difficulty    String?  // beginner, intermediate, advanced
  sourceUrl     String?  // Original source URL for scraped content
  sourceDomain  String?  // e.g., "nasa.gov", "khanacademy.org", "wikipedia.org"
  trustScore    Float    @default(0.8) // 0.0 to 1.0 - reliability score
  examRelevance String?  // high, medium, low - relevance to exams
  realWorldApp  Boolean  @default(false) // Has real-world applications
  interactive   Boolean  @default(false) // Has interactive content (simulations, etc.)
  
  uploadDate    DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]
  chapters      Chapter[]
  contentBlocks ContentBlock[]
  classMaterials ClassMaterial[]

  @@index([userId, educationSystem, level, subject])
  @@index([board, class, subject, year])
  @@index([userId, subject, chapterNumber])
  @@map("documents")
}

model DocumentChunk {
  id          String   @id @default(uuid())
  documentId  String
  chunkText   String   @db.Text
  chunkIndex  Int
  chapter     String?
  topic       String?
  metadata    Json?
  createdAt   DateTime @default(now())
  
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model ContentBlock {
  id          String   @id @default(uuid())
  documentId  String
  
  blockType   String   // introduction, explanation, definition, theorem, formula, solved_example, exercise_question, side_note, summary, diagram, table, section_header, chapter_header
  chapterNumber Int?
  pageNumber  Int
  position    Json?    // {x, y, width, height}
  
  content     Json     // Flexible content structure: {text, equations, images, formatting}
  
  // For searchability
  textContent String   @db.Text
  equations   String[]
  concepts    String[]
  
  createdAt   DateTime @default(now())
  
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  @@index([documentId, blockType, chapterNumber])
  @@index([documentId, pageNumber])
  @@map("content_blocks")
}

model Exam {
  id            String   @id @default(uuid())
  userId        String
  subject       String
  class         String
  section       String
  examType      String   // 'mid-term' | 'quiz' | 'practical' | 'final'
  chapterStart  Int?     // NULL for final exams
  chapterEnd    Int?     // NULL for final exams
  patternId     String?
  topics        String[]
  examContent   Json
  fileUrls      String[] // Array of generated file URLs
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern       Pattern? @relation(fields: [patternId], references: [id])

  @@map("exams")
}

model Pattern {
  id          String   @id @default(uuid())
  userId      String
  name        String
  subject     String
  totalMarks  Int
  duration    Int      // Duration in minutes
  sections    Json     // Array of section configurations
  lastUsed    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exams       Exam[]

  @@map("patterns")
}

model Chapter {
  id            String   @id @default(uuid())
  documentId    String
  chapterNumber Int
  chapterName   String
  startPosition Int
  endPosition   Int
  createdAt     DateTime @default(now())
  
  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chapterNumber])
  @@map("chapters")
}

model PastPaper {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  examType    String   // 'quiz', 'mid-term', 'final'
  year        Int
  board       String   // "Punjab Board"
  class       String
  fileName    String
  fileUrl     String
  fileSize    Int
  processed   Boolean  @default(false)
  extractionStatus  String   @default("uploaded") // uploaded | extracting | pending_review | approved | indexed | failed
  extractionDraft   Json?
  questionCount     Int?
  extractionMethod  String?  // gemini_vision | tesseract | legacy
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   PastPaperQuestion[]
  classMaterials ClassMaterial[]

  @@index([userId, subject, year])
  @@index([board, class, subject])
  @@map("past_papers")
}

model PastPaperQuestion {
  id              String   @id @default(uuid())
  pastPaperId     String
  questionText    String   @db.Text
  
  // Pattern Signature Fields 🔥
  concept         String   // "Quadratic Equations", "Trigonometry"
  method          String   // "Factorization", "Formula", "Substitution"
  structure       String   // "Standard Form", "Word Problem", "MCQ Concept"
  
  // Classification
  questionType    String   // "MCQ", "Short", "Long"
  chapter         Int?
  marks           Int
  difficulty      String   // "Easy", "Medium", "Hard"
  
  // Intelligence Fields
  frequency       Int      @default(1)
  lastAppeared    Int      // Year
  consistencyScore Float   @default(0)
  
  createdAt       DateTime @default(now())
  
  pastPaper       PastPaper @relation(fields: [pastPaperId], references: [id], onDelete: Cascade)
  cluster         PatternCluster? @relation(fields: [clusterId], references: [id])
  clusterId       String?

  @@index([chapter])
  @@index([concept, method, structure])
  @@map("past_paper_questions")
}

model PatternCluster {
  id                String   @id @default(uuid())
  
  // Pattern Signature
  concept           String
  method            String
  structure         String
  difficulty        String
  
  // Context
  subject           String
  board             String
  class             String
  chapter           Int?
  
  // Aggregated Intelligence
  totalFrequency    Int      @default(0)
  priorityScore     Float    @default(0)
  consistencyBonus  Float    @default(0)
  trend             String   @default("STABLE") // "RISING", "STABLE", "DECLINING"
  
  // Years appeared
  yearsAppeared     Int[]
  
  // Sample questions for reference
  sampleQuestions   String[] @db.Text
  
  questions         PastPaperQuestion[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([concept, method, structure, difficulty, subject, class])
  @@index([concept, method, structure, difficulty])
  @@index([priorityScore])
  @@index([subject, class, chapter])
  @@map("pattern_clusters")
}

model PatternCache {
  id          String   @id @default(uuid())
  board       String
  country     String?
  subject     String
  class       String
  year        String
  pattern     Json     // Cached pattern data
  cachedAt    DateTime @default(now())
  expiresAt   DateTime // Cache expiry (e.g., 30 days)
  
  @@unique([board, subject, class, year])
  @@index([board, subject, class])
  @@map("pattern_cache")
}

// ===== Pattern Template System =====
// Stores verified exam pattern templates that the AI learns from.
// When a pattern is corrected by admin/teacher, it becomes ground truth.
// Next time the same board+subject+class is requested, the verified template is used directly.

model PatternTemplate {
  id              String   @id @default(uuid())
  
  // Identification
  board           String   // "BISE Punjab", "Federal Board", "Cambridge O Level", etc.
  country         String   @default("Pakistan")
  subject         String   // "Mathematics", "English", "Islamiat", etc.
  classLevel      String   // "9", "10", "11", "12", "O1", "O2", "AS", "A2", "BS", "MS"
  educationLevel  String   @default("secondary") // primary, secondary, higher_secondary, undergraduate, graduate, phd, competitive
  
  // Pattern Data
  name            String   // "BISE Punjab Islamiat Class 11 2026"
  totalMarks      Int
  duration        Int      // Minutes
  sections        Json     // Array of PatternSection objects
  
  // Verification & Learning
  isVerified      Boolean  @default(false) // true = admin/teacher approved ground truth
  source          String   @default("ai") // "ai", "web_search", "manual", "admin_corrected"
  confidence      Float    @default(0.5) // 0.0-1.0, increases with verification
  usageCount      Int      @default(0) // How many times this template was used
  lastUsed        DateTime?
  
  // Metadata
  notes           String?  @db.Text // Admin notes about this template
  createdBy       String?  // userId of creator
  verifiedBy      String?  // userId of verifier
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([board, subject, classLevel, country])
  @@index([board, subject, classLevel])
  @@index([educationLevel])
  @@index([isVerified])
  @@map("pattern_templates")
}

// Audit trail for pattern corrections — permanent learning
model CorrectionLog {
  id              String   @id @default(uuid())
  templateId      String   // References PatternTemplate.id
  oldData         Json     // Previous pattern data before correction
  newData         Json     // New corrected pattern data
  correctedBy     String   // userId or 'admin'
  reason          String?  @db.Text // Why was it corrected
  sourceUrl       String?  // Link to official board notification if available
  createdAt       DateTime @default(now())
  
  @@index([templateId])
  @@map("correction_logs")
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  educationLevel  String              // matric | fsc | o_level | graduation | self_learner
  classGrade      String?             // 9 | 10 | 11 | 12
  group           String?             // pre_medical | pre_engineering | ics | icom | science | arts
  board           String?             // punjab | federal | sindh | kpk | cambridge
  degree          String?             // bs | bba | mbbs | be | other
  semester        String?             // 1–8
  subjects        String[]
  targetExam      String?             // mdcat | ecat | css | nts | none
  learningLevel   Int      @default(3) // 1-5 adaptive scale (1-2=struggling, 3=average, 4-5=quick learner)
  schoolName      String?
  city            String?
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("student_profiles")
}

model TeacherProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  subjectsTaught  String[]
  classesTaught   String[]
  board           String?
  institutionType String?             // school | college | academy | tutor
  schoolName      String?
  city            String?
  experienceYears Int?
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("teacher_profiles")
}

// Expected marks ranges per board+level — used for sanity checking AI output
model BoardConfig {
  id              String   @id @default(uuid())
  
  board           String   // "BISE Punjab", "Federal Board", etc.
  country         String   @default("Pakistan")
  educationLevel  String   // "secondary", "higher_secondary", etc.
  
  // Expected ranges
  minMarks        Int      // Minimum total marks for this board+level
  maxMarks        Int      // Maximum total marks
  defaultMarks    Int      // Most common total marks
  defaultDuration Int      // Minutes
  
  // Subject-specific overrides (JSON map: { "English": 100, "Physics": 85 })
  subjectMarks    Json?    // Override marks per subject
  
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([board, country, educationLevel])
  @@map("board_configs")
}

// ── Ustaad AI Chat Persistence ──────────────────────────────────────────────

model ChatSession {
  id        String        @id @default(uuid())
  userId    String
  title     String        @default("New Chat")
  subject   String?
  context   Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String      // 'user' | 'assistant'
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

// ── ExamGenie (student quiz layer) ───────────────────────────────────────────

model QuizSession {
  id            String   @id @default(uuid())
  userId        String
  subject       String
  board         String?
  class         String?
  chapterStart  Int?
  chapterEnd    Int?
  quizType      String   @default("mcq")
  mode          String   @default("smart")
  questionCount Int
  status        String   @default("ready")
  sourceSummary Json?
  isClassTemplate Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions     QuizQuestion[]
  attempts      QuizAttempt[]
  classAssignment ClassAssignment?

  @@index([userId, createdAt(sort: Desc)])
  @@map("quiz_sessions")
}

model QuizQuestion {
  id             String   @id @default(uuid())
  quizSessionId  String
  orderIndex     Int
  questionText   String   @db.Text
  questionType   String   @default("mcq")
  options        Json
  correctOption  String
  topicTag       String?
  concept        String?
  difficulty     String?
  explanation    String?  @db.Text

  quizSession    QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)

  @@index([quizSessionId, orderIndex])
  @@map("quiz_questions")
}

model QuizAttempt {
  id            String    @id @default(uuid())
  quizSessionId String
  userId        String
  score         Int?
  total         Int
  percentage    Float?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  quizSession   QuizSession     @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]

  @@index([userId, completedAt(sort: Desc)])
  @@index([quizSessionId])
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id              String  @id @default(uuid())
  attemptId       String
  questionId      String
  selectedOption  String?
  isCorrect       Boolean?

  attempt         QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("attempt_answers")
}

// ── Classroom (teacher ↔ student) ───────────────────────────────────────────

model Classroom {
  id          String   @id @default(uuid())
  teacherId   String
  name        String
  subject     String
  classGrade  String?
  board       String?
  joinCode    String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User              @relation("TeacherClassrooms", fields: [teacherId], references: [id], onDelete: Cascade)
  enrollments ClassEnrollment[]
  materials   ClassMaterial[]
  assignments ClassAssignment[]
  messages    ClassMessage[]
  questionBanks QuestionBank[]

  @@index([teacherId])
  @@map("classrooms")
}

model ClassEnrollment {
  id          String   @id @default(uuid())
  classroomId String
  studentId   String
  status      String   @default("active")
  joinedAt    DateTime @default(now())

  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student     User      @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classroomId, studentId])
  @@index([studentId])
  @@map("class_enrollments")
}

model ClassMaterial {
  id          String   @id @default(uuid())
  classroomId String
  teacherId   String
  documentId  String?
  pastPaperId String?
  title       String?
  note        String?
  sharedAt    DateTime @default(now())

  classroom   Classroom  @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     User       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  document    Document?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  pastPaper   PastPaper? @relation(fields: [pastPaperId], references: [id], onDelete: SetNull)

  @@index([classroomId, sharedAt(sort: Desc)])
  @@map("class_materials")
}

model ClassAssignment {
  id             String    @id @default(uuid())
  classroomId    String
  teacherId      String
  quizSessionId  String    @unique
  title          String
  instructions   String?   @db.Text
  assignmentMode   String    @default("practice")
  durationMinutes  Int?
  dueAt            DateTime?
  publishAt          DateTime?
  publishNotifiedAt  DateTime?
  proctoringEnabled  Boolean   @default(false)
  allowReviewAfterSubmit Boolean @default(true)
  status         String    @default("active")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  classroom      Classroom   @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher        User        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  quizSession    QuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  reminders      AssignmentReminder[]

  @@index([classroomId, status])
  @@map("class_assignments")
}

// ── Notifications (in-app + email triggers) ─────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String    @db.Text
  link      String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

model AssignmentReminder {
  id             String   @id @default(uuid())
  assignmentId   String
  userId         String
  reminderType   String   @default("due_24h")
  sentAt         DateTime @default(now())

  assignment ClassAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId, reminderType])
  @@index([assignmentId])
  @@map("assignment_reminders")
}

// ── Classroom group chat ─────────────────────────────────────────────────────

model ClassMessage {
  id          String   @id @default(uuid())
  classroomId String
  senderId    String
  messageType String   @default("text")
  content     String?  @db.Text
  fileUrl     String?
  fileName    String?
  mimeType    String?
  fileSize    Int?
  durationSec Int?
  replyToId   String?
  createdAt   DateTime @default(now())

  classroom Classroom     @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo   ClassMessage? @relation("ClassMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ClassMessage[] @relation("ClassMessageReplies")

  @@index([classroomId, createdAt(sort: Desc)])
  @@map("class_messages")
}

// ── Question bank (per classroom) ───────────────────────────────────────────

model QuestionBank {
  id          String   @id @default(uuid())
  classroomId String
  teacherId   String
  name        String
  subject     String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom          @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher     User               @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  items       QuestionBankItem[]

  @@index([classroomId, updatedAt(sort: Desc)])
  @@map("question_banks")
}

model QuestionBankItem {
  id            String   @id @default(uuid())
  bankId        String
  orderIndex    Int
  questionText  String   @db.Text
  questionType  String   @default("mcq")
  options       Json
  correctOption String
  topicTag      String?
  concept       String?
  difficulty    String?
  explanation   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bank          QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId, orderIndex])
  @@map("question_bank_items")
}
